NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=
REDIS_URL=redis://localhost:6379

# Optional: near-mint market for user_cards.acquisition_price (https://api.tcgpricelookup.com)
TCG_PRICE_LOOKUP_API_KEY=tcg_85aaca4dad46c881196c8d68f0328b93c04a62886f9f5bde
# Seconds (5–120, default 30). Short TTL for sale windows; same card_id hits Redis until expiry.
TCG_PRICE_LOOKUP_CACHE_TTL_SECONDS=30

# Pub/sub channel for card price updates (collection sockets subscribe on the primary Redis URL).
CARD_PRICE_BROADCAST_CHANNEL=pullvault:card_price_updates
